# Jellyfin + Telerising + EasyEPG - Projektvariablen (Docker Compose)
# Datei: .env  (liegt im gleichen Ordner wie docker-compose.yaml)
# Copyright Roman Glos 01.02.2026

# =========================================================
# Allgemein
# =========================================================
TZ=Europe/Berlin

# =========================================================
# Benutzer-/Gruppen-IDs
# =========================================================
# Für linuxserver.io Container:
# - PUID/PGID werden für Berechtigungen auf Host-Volumes verwendet.
PUID=1000
PGID=10

# Standard UMASK für Jellyfin (002 = Gruppen-Schreibrechte)
JELLYFIN_UMASK=002

# =========================================================
# Pfade am Host (NAS)
# =========================================================

# Medienverzeichnis (Bibliotheken)
MEDIA_DIR=/volume1/Jellyfin

# Jellyfin Konfiguration (standardmäßig im Projektordner)
JELLYFIN_CONFIG_DIR=./Jellyfin/config

# System-Verzeichnis (z.B. NVMe Volume) für Cache/Transcoding/temporäre Daten
# Wird in den Jellyfin-Container als /JellyfinSystem gemountet.
JELLYFIN_SYSTEM_DIR=/volume2/JellyfinSystem

# =========================================================
# SWAG (Reverse Proxy + Let's Encrypt + Fail2Ban)
# =========================================================
SWAG_URL=example.com
SWAG_SUBDOMAINS=jellyfin
SWAG_ONLY_SUBDOMAINS=true
SWAG_EMAIL=mail@example.com
SWAG_FAIL2BAN_ENABLED=true

# SWAG Konfiguration (standardmäßig im Projektordner)
SWAG_CONFIG_DIR=./linuxserver_swag/config

# =========================================================
# EasyEPG
# =========================================================
# EasyEPG nutzt USER_ID/GROUP_ID zur Rechtezuordnung.
USER_ID=1000
GROUP_ID=10

EASYEPG_UPDATE=yes
EASYEPG_REPO=script.service.easyepg-lite
EASYEPG_BRANCH=main
EASYEPG_PYTHONPATH=/easyepg/pylibs

# EasyEPG Verzeichnisse (standardmäßig im Projektordner)
EASYEPG_APP_DIR=./takealug_new-easyepg/easyepg
EASYEPG_XML_DIR=./takealug_new-easyepg/easyepg_xml

# =========================================================
# Telerising
# =========================================================
TELERISING_UID=1000
TELERISING_GID=10
TELERISING_UPDATE=yes

TELERISING_DIR=./telerising

# =========================================================
# Ports (Host -> Container)
# =========================================================

# Jellyfin
JELLYFIN_PORT_HTTP=8096
JELLYFIN_PORT_DISCOVERY_UDP=7359
JELLYFIN_PORT_DLNA_UDP=1900
# JELLYFIN_PORT_HTTPS=8920  # deaktiviert (TLS via SWAG)

# SWAG
SWAG_PORT_HTTP=5080
SWAG_PORT_HTTPS=50443
SWAG_PORT_JELLYFIN_SSL=8920
SWAG_PORT_DASH=58080

# EasyEPG / Telerising
EASYEPG_PORT=4000
TELERISING_PORT=5000
