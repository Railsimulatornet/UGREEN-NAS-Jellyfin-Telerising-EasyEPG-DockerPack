# Jellyfin + Telerising + EasyEPG - project variables (Docker Compose)
# File: .env (located in the same folder as docker-compose.yaml)
# Copyright Roman Glos 01.02.2026

# =========================================================
# General
# =========================================================
TZ=Europe/Berlin

# =========================================================
# User/Group IDs
# =========================================================
# For linuxserver.io containers:
# - PUID/PGID are used for permissions on host volumes.
PUID=1000
PGID=10

# Default UMASK for Jellyfin (002 = group write permissions)
JELLYFIN_UMASK=002

# =========================================================
# Paths on the host (NAS)
# =========================================================

# Media directory (libraries)
MEDIA_DIR=/volume1/Jellyfin

# Jellyfin configuration (by default in the project folder)
JELLYFIN_CONFIG_DIR=./Jellyfin/config

# System directory (e.g., NVMe volume) for cache/transcoding/temporary data
# Mounted into the Jellyfin container as /JellyfinSystem.
JELLYFIN_SYSTEM_DIR=/volume2/JellyfinSystem

# =========================================================
# SWAG (Reverse Proxy + Let's Encrypt + Fail2Ban)
# =========================================================
SWAG_URL=example.com
SWAG_SUBDOMAINS=jellyfin
SWAG_ONLY_SUBDOMAINS=true
SWAG_EMAIL=mail@example.com
SWAG_FAIL2BAN_ENABLED=true

# SWAG configuration (by default in the project folder)
SWAG_CONFIG_DIR=./linuxserver_swag/config

# =========================================================
# EasyEPG
# =========================================================
# EasyEPG uses USER_ID/GROUP_ID for permission mapping.
USER_ID=1000
GROUP_ID=10

EASYEPG_UPDATE=yes
EASYEPG_REPO=script.service.easyepg-lite
EASYEPG_BRANCH=main
EASYEPG_PYTHONPATH=/easyepg/pylibs

# EasyEPG directories (by default in the project folder)
EASYEPG_APP_DIR=./takealug_new-easyepg/easyepg
EASYEPG_XML_DIR=./takealug_new-easyepg/easyepg_xml

# =========================================================
# Telerising
# =========================================================
TELERISING_UID=1000
TELERISING_GID=10
TELERISING_UPDATE=yes

TELERISING_DIR=./telerising

# =========================================================
# Ports (host -> container)
# =========================================================

# Jellyfin
JELLYFIN_PORT_HTTP=8096
JELLYFIN_PORT_DISCOVERY_UDP=7359
JELLYFIN_PORT_DLNA_UDP=1900
# JELLYFIN_PORT_HTTPS=8920  # disabled (TLS via SWAG)

# SWAG
SWAG_PORT_HTTP=5080
SWAG_PORT_HTTPS=50443
SWAG_PORT_JELLYFIN_SSL=8920
SWAG_PORT_DASH=58080

# EasyEPG / Telerising
EASYEPG_PORT=4000
TELERISING_PORT=5000
